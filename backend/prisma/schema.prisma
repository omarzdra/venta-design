generator client {
  provider = "prisma-client-js"
  binaryTargets = ["native", "linux-musl-openssl-3.0.x", "rhel-openssl-3.0.x"]
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model Produkt {
  id             Int      @id @default(autoincrement())
  koda           String   @unique
  naziv_produkta String
  tip            String
  sirina         Float?
  nabavna_cena   Decimal  @db.Decimal(12, 2)
  prodajna_cena  Decimal  @db.Decimal(12, 2)
  dobavitelj     String?
  created_at     DateTime @default(now())

  lotProdukti    LotProdukt[]
  nakupPostavke  NakupPostavka[]

  @@index([naziv_produkta])
}

model LotProdukt {
  id              Int       @id @default(autoincrement())
  produkt_id      Int
  lot_stevilka    String?
  kolicina_tm     Float
  nabavna_cena    Decimal   @db.Decimal(12, 2)
  prodajna_cena   Decimal   @db.Decimal(12, 2)
  datum_prevzema  DateTime  @default(now())
  created_at      DateTime  @default(now())

  produkt         Produkt       @relation(fields: [produkt_id], references: [id])
  nakupPostavka   NakupPostavka? @relation("LotFromPostavka")
  materialiNalog  DelovnaNalogaMaterial[]
  inventuraLoti   InventuraLot[]

  @@index([produkt_id])
  @@index([datum_prevzema])
  @@index([kolicina_tm])
}

model Nakup {
  id              Int       @id @default(autoincrement())
  datum           DateTime
  dobavitelj      String
  stevilka_racuna String
  neto_znesek     Decimal   @db.Decimal(12, 2)
  bruto_znesek    Decimal   @db.Decimal(12, 2)
  created_at      DateTime  @default(now())

  postavke        NakupPostavka[]

  @@index([datum])
  @@index([stevilka_racuna])
}

model NakupPostavka {
  id              Int       @id @default(autoincrement())
  nakup_id        Int
  kategorija      String
  opis            String
  neto_cena       Decimal   @db.Decimal(12, 2)
  ddv             Float
  bruto_cena      Decimal   @db.Decimal(12, 2)
  produkt_id      Int?
  lot_stevilka    String?
  kolicina_tm     Float?
  kolicina_m2     Float?
  lot_produkt_id  Int?      @unique

  nakup           Nakup       @relation(fields: [nakup_id], references: [id], onDelete: Cascade)
  produkt         Produkt?    @relation(fields: [produkt_id], references: [id])
  lotProdukt      LotProdukt? @relation("LotFromPostavka", fields: [lot_produkt_id], references: [id])

  @@index([nakup_id])
  @@index([produkt_id])
}

model DelovnaNaloga {
  id                        Int       @id @default(autoincrement())
  tip                       String
  stevilka_delovnega_naloga String
  naziv_projekta            String
  status                    String    @default("v_izdelavi")
  stevilka_racuna           String?
  opis                      String?
  opomba                    String?
  kontakt_ime               String
  kontakt_gsm               String?
  kontakt_email             String?
  cena_dela_neto            Decimal?  @db.Decimal(12, 2)
  ddv_stopnja               Float?    @default(22)
  cena_dela_bruto           Decimal?  @db.Decimal(12, 2)
  cena_materiala            Decimal   @default(0) @db.Decimal(12, 2)
  datum                     DateTime  @default(now())
  potrjena_at               DateTime?
  created_at                DateTime  @default(now())

  vozilo                    Vozilo?
  poskodbe                  DelovnaNalogaPoskodba[]
  materiali                 DelovnaNalogaMaterial[]
  slike                     DelovnaNalogaSlika[]
  storitve                  DelovnaNalogaStoritev[]
  dnevniStrosek             DelovnaNalogaDnevniStrosek?

  @@index([tip, status, datum])
  @@index([datum])
  @@index([stevilka_delovnega_naloga])
  @@index([potrjena_at])
}

model Storitev {
  id             Int      @id @default(autoincrement())
  naziv          String
  eur_ura        Decimal  @db.Decimal(12, 2)
  nabavna_cena   Decimal  @default(0) @db.Decimal(12, 2)
  prodajna_cena  Decimal  @default(0) @db.Decimal(12, 2)
  created_at     DateTime @default(now())

  nalogaStoritve DelovnaNalogaStoritev[]

  @@index([naziv])
}

model DelovnaNalogaStoritev {
  id                Int     @id @default(autoincrement())
  delovna_naloga_id Int
  storitev_id       Int
  stevilo_ur        Float
  cena_skupaj       Decimal @db.Decimal(12, 2)

  naloga   DelovnaNaloga @relation(fields: [delovna_naloga_id], references: [id], onDelete: Cascade)
  storitev Storitev      @relation(fields: [storitev_id], references: [id])

  @@index([delovna_naloga_id])
  @@index([storitev_id])
}

model DelovnaNalogaDnevniStrosek {
  id                       Int     @id @default(autoincrement())
  delovna_naloga_id        Int     @unique
  dnevni_strosek           Decimal @db.Decimal(12, 2)
  stevilo_dni              Int
  skupaj                   Decimal @db.Decimal(12, 2)
  nabavni_dnevni_strosek   Decimal @default(0) @db.Decimal(12, 2)
  prodajni_dnevni_strosek  Decimal @default(0) @db.Decimal(12, 2)
  nabavni_skupaj           Decimal @default(0) @db.Decimal(12, 2)
  prodajni_skupaj          Decimal @default(0) @db.Decimal(12, 2)

  naloga DelovnaNaloga @relation(fields: [delovna_naloga_id], references: [id], onDelete: Cascade)
}

model Vozilo {
  id                  Int           @id @default(autoincrement())
  delovna_naloga_id   Int           @unique
  registrska_stevilka String?
  stevilka_sasije     String
  znamka_vozila       String

  naloga              DelovnaNaloga @relation(fields: [delovna_naloga_id], references: [id], onDelete: Cascade)
}

model DelovnaNalogaPoskodba {
  id                Int           @id @default(autoincrement())
  delovna_naloga_id Int
  opis              String

  naloga            DelovnaNaloga @relation(fields: [delovna_naloga_id], references: [id], onDelete: Cascade)

  @@index([delovna_naloga_id])
}

model DelovnaNalogaMaterial {
  id                Int           @id @default(autoincrement())
  delovna_naloga_id Int
  lot_produkt_id    Int
  kolicina_tm       Float

  naloga            DelovnaNaloga @relation(fields: [delovna_naloga_id], references: [id], onDelete: Cascade)
  lotProdukt        LotProdukt    @relation(fields: [lot_produkt_id], references: [id])

  @@index([delovna_naloga_id])
  @@index([lot_produkt_id])
}

model DelovnaNalogaSlika {
  id                Int           @id @default(autoincrement())
  delovna_naloga_id Int
  url               String

  naloga            DelovnaNaloga @relation(fields: [delovna_naloga_id], references: [id], onDelete: Cascade)

  @@index([delovna_naloga_id])
}

model PrihodekManual {
  id              Int       @id @default(autoincrement())
  datum           DateTime
  opis            String
  narocnik        String?
  stevilka_racuna String?
  neto_znesek     Decimal   @db.Decimal(12, 2)
  ddv             Float
  bruto_znesek    Decimal   @db.Decimal(12, 2)
  created_at      DateTime  @default(now())

  @@index([datum])
  @@index([stevilka_racuna])
}

model Inventura {
  id         Int      @id @default(autoincrement())
  datum      DateTime
  zakljucena Boolean  @default(false)
  created_at DateTime @default(now())

  loti InventuraLot[]

  @@index([datum])
}

model InventuraLot {
  id             Int     @id @default(autoincrement())
  inventura_id   Int
  lot_produkt_id Int
  oznacen        Boolean @default(false)

  inventura  Inventura  @relation(fields: [inventura_id], references: [id], onDelete: Cascade)
  lotProdukt LotProdukt @relation(fields: [lot_produkt_id], references: [id])

  @@index([inventura_id])
  @@index([lot_produkt_id])
}
